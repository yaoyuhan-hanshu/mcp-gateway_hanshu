# ==========================================
# Docker 构建忽略文件
# ==========================================
# 避免把无关文件打进镜像，减小体积、加速构建

# 环境变量 (绝不打包进镜像)
.env
.env.local
.env.*

# Python 缓存
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.pytest_cache/
.mypy_cache/

# 虚拟环境
venv/
.venv/
env/

# 版本控制
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp

# 日志
logs/
*.log

# 系统
.DS_Store
Thumbs.db

# 文档 (可选，打包不影响运行)
*.md